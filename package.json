{
  "name": "fastify-template",
  "version": "0.0.0",
  "description": "Fastify + TS project template",
  "private": true,
  "main": "src/server.ts",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx watch --env-file=.env .",
    "build": "tsc",
    "lint": "eslint .",
    "format": "prettier --write . --config .prettierrc",
    "typecheck": "tsc --noEmit",
    "deploy:start": "docker compose up --build",
    "deploy:stop": "docker compose down --remove-orphans"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DanielUsov/fastify-template.git"
  },
  "keywords": [],
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "author": "Daniel Usov",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/DanielUsov/fastify-template/issues"
  },
  "homepage": "https://github.com/DanielUsov/fastify-template#readme",
  "dependencies": {
    "@fastify/env": "6.0.0",
    "@fastify/sensible": "6.0.4",
    "close-with-grace": "2.5.0",
    "fastify": "5.8.5",
    "@fastify/autoload": "6.3.1",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "5.2.6",
    "fastify-plugin": "5.1.0",
    "pino-pretty": "13.1.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@fastify/type-provider-json-schema-to-ts": "5.0.0",
    "@types/node": "25.6.2",
    "@typescript-eslint/parser": "8.59.2",
    "eslint": "10.3.0",
    "fastify-tsconfig": "3.0.0",
    "prettier": "3.8.3",
    "ts-node": "10.9.2",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2"
  }
}
